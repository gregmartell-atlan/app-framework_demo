# Environment variables for local development
# Copy this to .env and fill in your values

# GitHub credentials (for live testing)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_ORG=gregmartell-atlan

# Atlan connection (for publishing assets)
ATLAN_API_KEY=your_atlan_api_key_here
ATLAN_BASE_URL=https://your-tenant.atlan.com

# Temporal configuration (optional — defaults to localhost for dev)
ATLAN_TEMPORAL_HOST=localhost:7233
ATLAN_TEMPORAL_NAMESPACE=default
ATLAN_TASK_QUEUE=github-task-queue

# App runtime configuration
ATLAN_APP_MODULE=app.connector:GitHubConnector
ATLAN_LOG_LEVEL=INFO
ATLAN_HANDLER_PORT=8000
ATLAN_HEALTH_PORT=8081

# Git low-speed timeout (for wiki cloning)
GIT_HTTP_LOW_SPEED_LIMIT=1000
GIT_HTTP_LOW_SPEED_TIME=120

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=atlan-github-app
